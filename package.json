{
  "name": "zyndai",
  "version": "0.2.4",
  "description": "Multi-framework AI agent SDK for the Zynd AI Network. Ed25519 Identity, Agent Discovery, HTTP Webhooks, Agent Cards, and x402 Micropayments.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "zynd": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && chmod +x dist/cli/index.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.2.0",
    "@noble/hashes": "^1.7.0",
    "@noble/curves": "^1.8.0",
    "@noble/ciphers": "^1.2.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "chalk": "^4.1.2",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "viem": "^2.23.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Zynd AI",
  "homepage": "https://github.com/zyndai/zyndai-ts-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zyndai/zyndai-ts-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/zyndai/zyndai-ts-sdk/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "sdk",
    "zyndai",
    "x402",
    "micropayments",
    "ed25519",
    "agent-network",
    "webhook"
  ],
  "publishConfig": {
    "access": "public"
  }
}
